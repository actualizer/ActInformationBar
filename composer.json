{
  "name": "act/information-bar",
  "description": "A plugin to display a time-controlled information bar with a customizable message.",
  "type": "shopware-platform-plugin",
  "license": "MIT",
  "version": "1.0.4",
  "authors": [
    {
      "name": "Ralph Geldmacher",
      "email": "ralph@actualize.de",
      "homepage": "https://www.actualize.de"
    }
  ],
  "require": {
    "shopware/core": ">=6.6 <=6.8",
    "shopware/storefront": ">=6.6 <=6.8",
    "php": ">=8.2"
  },
  "autoload": {
    "psr-4": {
      "Act\\InformationBar\\": "src/"
    }
  },
  "extra": {
    "shopware-plugin-class": "Act\\InformationBar\\ActInformationBar",
    "label": {
      "de-DE": "Actualize: Zeitgesteuerte Informationszeile",
      "en-GB": "Actualize: Time-controlled Information Bar"
    }
  }
}
